<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        Step 1: Define the BookRepository bean.
        Spring creates this object first since BookService depends on it.
    -->
    <bean id="bookRepository" class="com.library.repository.BookRepository"/>

    <!--
        Step 2: Define the BookService bean.
        Use <property> tag for SETTER INJECTION.
        - name="bookRepository"  → Spring will call setBookRepository()
        - ref="bookRepository"   → refers to the bean defined above
        This is different from Exercise 1 which used constructor-arg.
    -->
    <bean id="bookService" class="com.library.service.BookService">
        <property name="bookRepository" ref="bookRepository"/>
    </bean>

</beans>
